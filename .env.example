NODE_ENV=development
API_PORT=3000
JWT_SECRET=change-me
JWT_EXPIRES_IN_SECONDS=86400
CREDENTIAL_ENCRYPTION_KEY=change-me-32-byte-credential-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_arb_console
POSTGRES_USER=quant_arb
POSTGRES_PASSWORD=quant_arb

REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672
VITE_API_BASE_URL=http://localhost:3000/api/v1
# Optional: set these when Node cannot reach exchange public APIs directly.
# HTTP_PROXY=http://127.0.0.1:15236
# HTTPS_PROXY=http://127.0.0.1:15236

# Safety: default mode is mock-only. testnet/live currently use public market data only;
# authenticated order placement is intentionally not implemented yet.
EXCHANGE_MODE=mock
ENABLE_LIVE_TRADING=false
